NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_DATABASE=storage_calculator
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_MIN_SECRET
JWT_EXPIRES_IN=7d
# Auth endpoint rate limit (requests per 60 s). Raise in E2E/CI environments.
THROTTLE_LIMIT=10

# Optional: external Cargo (data normalization) service
# Example: http://localhost:8000
CARGO_URL=
# Shared secret header value to send as X-CARGO-API-KEY
CARGO_API_KEY=

# Optional bearer token; if set, backend will also send
# Authorization: Bearer <CARGO_API_TOKEN> when calling Cargo
CARGO_API_TOKEN=
